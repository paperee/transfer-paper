[["sora", "\u4ee5\u524d\u4e00\u76f4\u89c9\u5f97ee\u5728\u5305\u5bb9zhr\u7684\u5404\u79cd\u884c\u4e3a\uff0c\u770b\u6765\u786e\u5b9e\u5982\u6b64", 1691919822], ["sora", ">\u6211\u4e4b\u524d\u4e13\u95e8\u5199\u8fc7\u4e00\u7bc7\u6587\u7ae0 \u201c\u9510\u8bc4\u201d ZHR\uff0c\u7591\u95ee \u201c\u4ec0\u4e48\u6837\u7684\u5bb6\u5ead\u80fd\u628a\u4ed6\u6559\u6210\u8fd9\u6837\u201d\u3002\u8fd9\u4e0b\u4ed6\u521a\u597d\u63d0\u5230\u4ed6\u7236\u4eb2\uff0c\u8fd8\u611f\u6168\u81f3\u5c11\u4ed6\u6bd4\u4ed6\u7238\u5f00\u653e\u591a\u4e86\uff0c\u4ed6\u7238\u4e0d\u5141\u8bb8\u4e01\u514b\u5b58\u5728\uff0c\u4ed6\u81f3\u5c11\u8fd8\u5141\u8bb8\u4e86\u3002\u53ef\u80fd\u53ea\u662f ZHR \u60f3\u5f53\u4e01\u514b\u3002\r\n>\u6697\u81ea\u5410\u69fd\u8bf4\uff0cZHR \u662f \u201c\u6559\u79d1\u4e66\u7684\u4fe1\u5f92\u201d\uff0c\u4fd7\u79f0\uff1a\u201c\u4e66\u5446\u5b50\u201d\u3002\r\n\r\n\u8bf4\u5b9e\u8bdd\u4e2d\u56fd\u5f88\u591a\u5bb6\u5ead\u90fd\u8fd9\u6837\uff0c\u800c\u4e14\u8fd9\u4e0e\u4e2d\u56fd\u7684\u6559\u80b2\u6709\u5f88\u5927\u8054\u7cfb\u3002\r\n\r\n\u9996\u5148\u540c\u6027\u604b\u95ee\u9898\uff0c\u5176\u5b9ezhr\u4ece\u751f\u7406\u4e0a\u8fd9\u6837\u60f3\u4e5f\u6709\u4ed6\u81ea\u5df1\u7684\u9053\u7406\uff0c\u91cd\u70b9\u662f\u4f60\u4e4b\u6240\u4ee5\u611f\u89c9ZHR\u4e0e\u4f60\u4eec\uff08\u5176\u4ed6\u7528\u6237\uff09\u4e0d\u592a\u50cf\u662f\u56e0\u4e3a\u80fd\u7559\u5728hc\u7684\u4eba\u5f88\u591a\u601d\u60f3\u90fd\u4e0d\u592a\u7b80\u5355\uff0c\u793e\u4f1a\u4e0a\u5f88\u591a\u4eba\u90fd\u662f\u4e0d\u80fd\u63a5\u53d7\u540c\u6027\u604b\u7684.\r\n\r\n\u518d\u6765\u90a3\u4e2a\u201c\u4e66\u5446\u5b50\u201d\uff0c\u7531\u4e8e\u4e2d\u5171\u704c\u8f93\u7684\u4ef7\u503c\u89c2\u4e5f\u8ba9\u5f88\u591a\u5b66\u751f\u90fd\u76f2\u4ece\u8bfe\u672c\u4e2d\u7684\u5185\u5bb9\uff08\u5c24\u5176\u653f\u6cbb\u65b9\u9762\uff09,\u6211\u4eec\u4e4b\u524d\u73ed\u91cc\u540c\u5b66\u90fd\u5bf9\u8bfe\u672c\u91cc\u7684\u5185\u5bb9\u6df1\u4fe1\u4e0d\u7591\u7684\u3002\r\n\r\n\u5f53\u7136\u8fd9\u4e0e\u5bb6\u5ead\u73af\u5883\u4e5f\u6709\u5173\u7cfb\uff0c\u53ef\u80fdzhr\u5bb6\u5ead\u601d\u60f3\u4e0d\u592a\u5f00\u660e\u4e0d\u591fopen\u3002", 1691920894], ["qln", "\u786e\u5b9ezhang\u5728\u8fd9\u65b9\u9762\u4e5f\u6709\u8fd9\u4e2a\u7f3a\u70b9\uff0c\u5728\u8fd9\u65b9\u9762\u6211\u8fd8\u662f\u8ba4\u540cee\u7684", 1691922956], ["MrZhang365", "https://blog.mrzhang365.cf/article/#2ce34d2d-5714-4794-bccd-4eb697ead4a0", 1691936623], ["qln", "\u6211\u7684\u95ee\u9898\u6211\u7684\u95ee\u9898", 1691938759], ["paperee", "\u597d\u5bb6\u4f19 \u539f\u6765qln\u662fQLY", 1691939086], ["MrZhang365", "\u76f2\u731csora\u662ffish", 1691942653], ["22c", "~~ZHR\u8fd9\u7f51\u901f\u7528\u7684\u662f\u7a84\u5e26\u4e0a\u7f51\u5417~~", 1691945381], ["MrZhang365", "woc\uff0c\u6211\u7684WiFi\u2026", 1691945882], ["\u7384\u5fae", ">\u4ed6\u8fd8\u6839\u636e\u751f\u7269\u4e66\u4e0a\u52a8\u7269\u7e41\u6b96\u7684\u9053\u7406\uff0c\u5206\u6790\u9053\uff1a\u4eba\u4e0e\u4eba\u4e4b\u6240\u4ee5\u4f1a\u76f8\u7231\uff0c\u662f\u4e3a\u4e86\u7e41\u6b96\u4e0b\u4e00\u4ee3\u3002\u8fd9\u662f\u751f\u7269\u7684\u672c\u80fd\uff0c\r\n\r\nemm\u8bdd\u8bf4\u4e3a\u5565\u6211\u7ffb\u4e86\u751f\u7269\u4e66\u6ca1\u627e\u5230 \uff08 \u8fd8\u6709 \u6211\u4e0d\u662f\u540c\u6027\u604b", 1692846249], ["TheBigPig", "\u522b\u8dd1\u8def\uff0cuwuOS\u8fd8\u6709\u4e00\u5806bug\u5462", 1693400592], ["paperee", "@TheBigPig \u539f\u6765\u662f\u4f60\u7528\u4e86uwuOS\uff08", 1703388438]]